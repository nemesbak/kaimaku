# Copy to .env (never commit the real file) and fill in your values.

# Comma-separated list of library folders to expose, as seen inside the
# container (i.e. relative to the /media mount in docker-compose.yml).
MEDIA_ROOTS=/media/anime,/media/series,/media/peliculas

JELLYFIN_URL=http://host.docker.internal:8096
JELLYFIN_API_KEY=

EMBY_URL=http://host.docker.internal:8097
EMBY_API_KEY=
