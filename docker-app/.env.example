# Copy to .env (never commit the real file) and fill in your values.

# --- host paths (docker-compose.yml volumes) ---
# Where your actual media lives on the host, and a small folder for Kaimaku's
# own state (backups + job scratch space). Absolute paths recommended.
MEDIA_HOST_PATH=/mnt/user/datos/media
DATA_HOST_PATH=/mnt/user/datos/media/_theme_tools/kaimaku-data

# --- container / port ---
CONTAINER_NAME=kaimaku
PORT=8098

# --- libraries ---
# Comma-separated list of library folders to expose, as seen inside the
# container (i.e. relative to the /media mount in docker-compose.yml, not
# MEDIA_HOST_PATH above).
MEDIA_ROOTS=/media/anime,/media/series,/media/peliculas

# --- Jellyfin/Emby (optional) ---
# Leave the API keys empty to skip library refresh after install — everything
# else still works. host.docker.internal reaches services running directly on
# the host; use a container name instead if Jellyfin/Emby are on this same
# compose network.
JELLYFIN_URL=http://host.docker.internal:8096
JELLYFIN_API_KEY=

EMBY_URL=http://host.docker.internal:8097
EMBY_API_KEY=
